# .streamlit/secrets.toml 配置模板
# 复制此文件为 secrets.toml 并填入真实值，切勿将 secrets.toml 提交到版本控制。

# ── 必需配置项 ──────────────────────────────────────────────────────────────

# PostgreSQL 连接串（Neon / Supabase / 自托管均可）
DATABASE_URL = "postgresql://user:password@host:5432/dbname"

# OpenAI 兼容 API Key（硅基流动等第三方服务同样适用）
LLM_API_KEY = "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# API Base URL（OpenAI 官方填 https://api.openai.com/v1，硅基流动填对应地址）
LLM_BASE_URL = "https://api.siliconflow.cn/v1"

# 对话模型名称（如 gpt-4o、deepseek-ai/DeepSeek-V3 等）
LLM_CHAT_MODEL = "deepseek-ai/DeepSeek-V3"

# Embedding 模型名称（如 text-embedding-3-small、BAAI/bge-m3 等）
LLM_EMBEDDING_MODEL = "BAAI/bge-m3"

# ── 可选配置项（有默认值，可不填）────────────────────────────────────────────

# 向量相关性阈值，低于此值视为"资料相关性不足"（默认 0.3）
# SIMILARITY_THRESHOLD = 0.3

# 文本分块大小，单位：字符（默认 1000）
# CHUNK_SIZE = 1000

# 相邻分块重叠字符数（默认 200）
# CHUNK_OVERLAP = 200

# 视觉模型（用于图片 OCR，需支持视觉输入，默认 Qwen2.5-VL-7B-Instruct）
# LLM_VISION_MODEL = "Qwen/Qwen2.5-VL-7B-Instruct"
